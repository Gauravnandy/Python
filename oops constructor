## same code(things) but using constructer__init__() function (dunder method)

class Employee:
    # language = "python"
    # salary = 100000
    def __init__(self , name , salary , language): ####dunder method that is automatically called when an object is called
        self.name = name
        self.salary=salary
        self.language=language
        print("i am creating an object ")
    
    def getInfo(self): # method
        print(f"The language is {self.language}. The salary is {self.salary}")
    @staticmethod
    def greet():  # self is used to pass the object
        print("good morning")
        
harry = Employee("gaurav", 1300000, "python")
print(harry.name, harry.salary, harry.language)
