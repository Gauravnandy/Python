    ##### Multiple Inheritance
    
class Employee:
    company ="ITC"
    name="Default name"
    def show(self):
        print(f"The name is {self.name} and the salary is {self.company}")

class Coder:
    language="python"
    def printLanguages(self):
        print(f"out of all the languages here is your language:{self.language} ")

class Programmer(Employee, Coder): # programmer is inheriting from employee and coder
    company ="ITC Infotech"
    # def show(self):
    #     print(f"the name is {self.name} and the salary is {self.salary}")
    def showLanguage(self):
        print(f"the name is {self.company} he is good with language {self.language} ")
        
# class Programmer(Employee):   ## Programmer is inheriting from Employee
